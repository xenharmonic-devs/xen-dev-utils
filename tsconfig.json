{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "lib": [
      "es2020"
    ],
    "target": "es2020",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__/**",
    "src/__benchmarks__/**"
  ]
}
