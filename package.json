{
  "name": "xen-dev-utils",
  "author": "Lumi Pakkanen",
  "version": "0.12.2",
  "description": "Utility functions used by the Scale Workshop ecosystem",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenharmonic-devs/xen-dev-utils.git"
  },
  "bugs": {
    "url": "https://github.com/xenharmonic-devs/xen-dev-utils/issues"
  },
  "homepage": "https://github.com/xenharmonic-devs/xen-dev-utils#readme",
  "keywords": [
    "Microtonal",
    "Music",
    "Xenharmonic"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/frostburn"
  },
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "gts": "^7.0.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "test": "vitest",
    "fuzz": "FUZZ=1 vitest --testTimeout=0",
    "compile-legacy": "tsc -p tsconfig-legacy.json",
    "prebench": "npm run compile && npm run compile-legacy",
    "bench": "vitest bench",
    "doc": "typedoc src/index.ts --name xen-dev-utils"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./fraction": {
      "types": "./dist/fraction.d.ts",
      "import": "./dist/fraction.js",
      "require": "./dist/fraction.js",
      "default": "./dist/fraction.js"
    },
    "./primes": {
      "types": "./dist/primes.d.ts",
      "import": "./dist/primes.js",
      "require": "./dist/primes.js",
      "default": "./dist/primes.js"
    },
    "./conversion": {
      "types": "./dist/conversion.d.ts",
      "import": "./dist/conversion.js",
      "require": "./dist/conversion.js",
      "default": "./dist/conversion.js"
    },
    "./combinations": {
      "types": "./dist/combinations.d.ts",
      "import": "./dist/combinations.js",
      "require": "./dist/combinations.js",
      "default": "./dist/combinations.js"
    },
    "./monzo": {
      "types": "./dist/monzo.d.ts",
      "import": "./dist/monzo.js",
      "require": "./dist/monzo.js",
      "default": "./dist/monzo.js"
    },
    "./approximation": {
      "types": "./dist/approximation.d.ts",
      "import": "./dist/approximation.js",
      "require": "./dist/approximation.js",
      "default": "./dist/approximation.js"
    },
    "./number-array": {
      "types": "./dist/number-array.d.ts",
      "import": "./dist/number-array.js",
      "require": "./dist/number-array.js",
      "default": "./dist/number-array.js"
    },
    "./matrix": {
      "types": "./dist/matrix.d.ts",
      "import": "./dist/matrix.js",
      "require": "./dist/matrix.js",
      "default": "./dist/matrix.js"
    },
    "./package.json": "./package.json"
  },
  "type": "module"
}
